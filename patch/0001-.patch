Content-Transfer-Encoding: 8bit

---
 example/QCefViewTest/CMakeLists.txt           | 12 ++++--
 generate-win-x86_64.bat                       |  4 +-
 include/QCefView.h                            | 10 ++++-
 .../CCefClientDelegate_ContextMenuHandler.cpp | 38 ++++++++++++++++++-
 4 files changed, 58 insertions(+), 6 deletions(-)

diff --git a/example/QCefViewTest/CMakeLists.txt b/example/QCefViewTest/CMakeLists.txt
index 93a5a04..3291138 100644
--- a/example/QCefViewTest/CMakeLists.txt
+++ b/example/QCefViewTest/CMakeLists.txt
@@ -14,14 +14,18 @@ get_target_property(_qmake_executable Qt${QT_VERSION_MAJOR}::qmake IMPORTED_LOCA
 get_filename_component(_qt_bin_dir "${_qmake_executable}" DIRECTORY)
 
 if(OS_WINDOWS)
-  find_program(DEPLOYQT_EXECUTABLE windeployqt HINTS "${_qt_bin_dir}")
+  set(DEPLOYQT_EXECUTABLE "${_qt_bin_dir}/windeployqt.exe")
 elseif(OS_MACOS)
-  find_program(DEPLOYQT_EXECUTABLE macdeployqt HINTS "${_qt_bin_dir}")
+  set(DEPLOYQT_EXECUTABLE "${_qt_bin_dir}/macdeployqt")
 elseif(OS_LINUX)
 elseif(OS_MACOS)
 else()
 endif()
 
+if(NOT EXISTS "${DEPLOYQT_EXECUTABLE}")
+  message(FATAL_ERROR "DEPLOYQT_EXECUTABLE not found: ${DEPLOYQT_EXECUTABLE}")
+endif()
+
 # Create an empty source file as the rebuild trigger
 # QCefView will update this file every time it gets built
 file(WRITE ${CMAKE_BINARY_DIR}/auto_rebuild.cpp "/* Auto Rebuild Trigger */")
@@ -121,7 +125,9 @@ if(OS_WINDOWS)
     $<TARGET_FILE_DIR:${PROJECT_NAME}>/webres
 
     # Deploy the Qt Application
-    COMMAND ${DEPLOYQT_EXECUTABLE}
+    COMMAND ${CMAKE_COMMAND} -E env
+    "PATH=${_qt_bin_dir};$ENV{PATH}"
+    ${DEPLOYQT_EXECUTABLE}
     --no-svg
     --no-translations
     --no-compiler-runtime
diff --git a/generate-win-x86_64.bat b/generate-win-x86_64.bat
index 300e2bc..e5ba91a 100644
--- a/generate-win-x86_64.bat
+++ b/generate-win-x86_64.bat
@@ -1,7 +1,9 @@
 cmake -S . ^
 -B .build/windows.x86_64 ^
+-G "Visual Studio 16 2019" ^
 -A x64 ^
 -DPROJECT_ARCH=x86_64 ^
 -DBUILD_DEMO=ON ^
+-DQT_SDK_DIR:PATH="%QTDIR%" ^
 -DCMAKE_INSTALL_PREFIX:PATH="%cd%/out/windows.x86_64" ^
-%*
\ No newline at end of file
+%*
diff --git a/include/QCefView.h b/include/QCefView.h
index cf813e4..ffa7d01 100644
--- a/include/QCefView.h
+++ b/include/QCefView.h
@@ -1,4 +1,4 @@
-﻿/*
+/*
  * File: QCefView.h
  * Project: QCefView
  * Created: 29th March 2016
@@ -437,6 +437,14 @@ signals:
   /// <param name="window">The native browser windows</param>
   void nativeBrowserCreated(QWindow* window);
 
+  /// <summary>
+  /// Gets called when a custom context menu command is invoked
+  /// </summary>
+  /// <param name="commandId">The command id (e.g. 26600 for open link in new tab)</param>
+  /// <param name="linkUrl">The URL of the link, if any</param>
+  /// <param name="imageUrl">The URL of the image, if any</param>
+  void contextMenuCommandInvoked(int commandId, const QString& linkUrl, const QString& imageUrl);
+
 protected:
   /// <summary>
   /// Gets called before a new browser created (only for browser created by non-JavaScript)
diff --git a/src/details/handler/CCefClientDelegate_ContextMenuHandler.cpp b/src/details/handler/CCefClientDelegate_ContextMenuHandler.cpp
index a5e2f3e..ef9534d 100644
--- a/src/details/handler/CCefClientDelegate_ContextMenuHandler.cpp
+++ b/src/details/handler/CCefClientDelegate_ContextMenuHandler.cpp
@@ -1,4 +1,4 @@
-﻿#include "details/CCefClientDelegate.h"
+#include "details/CCefClientDelegate.h"
 
 #include <QDebug>
 #include <QThread>
@@ -36,6 +36,24 @@ CCefClientDelegate::onBeforeContextMenu(CefRefPtr<CefBrowser>& browser,
     return;
   }
 
+  // Add custom context menu items
+  const int MENU_ID_OPEN_LINK_IN_NEW_TAB = 26600;
+  const int MENU_ID_OPEN_IMAGE_IN_NEW_TAB = 26601;
+  const int MENU_ID_SAVE_IMAGE_AS = 26602;
+  const int MENU_ID_COPY_IMAGE = 26603;
+
+  if (params->HasImageContents() && !params->GetSourceUrl().empty()) {
+    model->InsertItemAt(0, MENU_ID_COPY_IMAGE, "Copy image");
+    model->InsertItemAt(0, MENU_ID_SAVE_IMAGE_AS, "Save image as...");
+    model->InsertItemAt(0, MENU_ID_OPEN_IMAGE_IN_NEW_TAB, "Open image in new tab");
+    model->InsertSeparatorAt(3);
+  }
+
+  if (!params->GetLinkUrl().empty()) {
+    model->InsertItemAt(0, MENU_ID_OPEN_LINK_IN_NEW_TAB, "Open link in new tab");
+    model->InsertSeparatorAt(1);
+  }
+
   if (pCefViewPrivate->isOSRModeEnabled_) {
     // OSR mode
     auto menuData = MenuBuilder::CreateMenuDataFromCefMenu(model.get());
@@ -83,6 +101,24 @@ CCefClientDelegate::onContextMenuCommand(CefRefPtr<CefBrowser>& browser,
                                          CefContextMenuHandler::EventFlags event_flags)
 {
   FLog();
+  AcquireAndValidateCefViewPrivateWithReturn(pCefViewPrivate, false);
+
+  const int MENU_ID_OPEN_LINK_IN_NEW_TAB = 26600;
+  const int MENU_ID_OPEN_IMAGE_IN_NEW_TAB = 26601;
+  const int MENU_ID_SAVE_IMAGE_AS = 26602;
+  const int MENU_ID_COPY_IMAGE = 26603;
+
+  if (command_id >= MENU_ID_OPEN_LINK_IN_NEW_TAB && command_id <= MENU_ID_COPY_IMAGE) {
+    QString linkUrl = QString::fromStdString(params->GetLinkUrl().ToString());
+    QString imageUrl = QString::fromStdString(params->GetSourceUrl().ToString());
+    
+    runInMainThread([pCefViewPrivate, command_id, linkUrl, imageUrl]() {
+      if (pCefViewPrivate->q_ptr) {
+        emit pCefViewPrivate->q_ptr->contextMenuCommandInvoked(command_id, linkUrl, imageUrl);
+      }
+    });
+    return true;
+  }
 
   return false;
 }
-- 
